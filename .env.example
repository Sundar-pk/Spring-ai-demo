# Copy this to .env and fill in your values
# Then run: export $(cat .env | xargs) && ./mvnw spring-boot:run

# Your internal company LLM server (must expose OpenAI-compatible /v1 API)
# Common implementations: vLLM, text-generation-inference, Azure OpenAI, Ollama
INTERNAL_LLM_URL=http://ai-platform.internal/v1

# API key from your IAM portal / AI Platform admin
INTERNAL_LLM_API_KEY=your-api-key-here

# Model name as it's registered on your internal server
INTERNAL_LLM_MODEL=your-model-name

# Embedding model (for RAG) — can be same server, different model endpoint
INTERNAL_EMBEDDING_MODEL=text-embedding-ada-002
