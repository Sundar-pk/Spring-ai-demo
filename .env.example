# ============================================================
# Jenkins AI Monitor — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to Git (add it to .gitignore).
# ============================================================

# Jenkins connection
JENKINS_BASE_URL=http://jenkins.bank.internal:8080
JENKINS_JOB_NAME=payments/nightly-build
JENKINS_USERNAME=your-jenkins-username
JENKINS_API_TOKEN=your-jenkins-api-token-here

# LLM connection (OpenAI-compatible API via your proxy)
SPRING_AI_OPENAI_BASE_URL=http://llm-proxy.bank.internal:8080/v1
SPRING_AI_OPENAI_API_KEY=your-llm-api-key-here
LLM_MODEL_NAME=your-model-name

# Monitoring settings
MONITOR_POLL_INTERVAL_MS=300000    # 5 minutes = 300000 ms
MONITOR_OUTPUT_DIR=./fix-reports
JENKINS_LOG_MAX_LINES=200

# Auto-fix via Git (set to true when Git integration is ready)
MONITOR_AUTO_FIX_ENABLED=false
